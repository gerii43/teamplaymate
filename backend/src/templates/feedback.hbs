<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>New Feedback - {{platformName}}</title>
    <style>
        body { font-family: Arial, sans-serif; line-height: 1.6; color: #333; }
        .container { max-width: 600px; margin: 0 auto; padding: 20px; }
        .header { background: #F59E0B; color: white; padding: 20px; text-align: center; border-radius: 10px 10px 0 0; }
        .content { background: #f9f9f9; padding: 30px; border-radius: 0 0 10px 10px; }
        .feedback-box { background: white; padding: 20px; border-left: 4px solid #F59E0B; margin: 20px 0; }
        .rating { color: #F59E0B; font-size: 20px; }
    </style>
</head>
<body>
    <div class="container">
        <div class="header">
            <h1>New Feedback Received</h1>
        </div>
        <div class="content">
            <h2>Feedback Details</h2>
            
            <div class="feedback-box">
                <p><strong>From:</strong> {{name}} ({{email}})</p>
                <p><strong>Category:</strong> {{category}}</p>
                {{#if rating}}
                <p><strong>Rating:</strong> <span class="rating">{{rating}}/5 ⭐</span></p>
                {{/if}}
                <p><strong>Timestamp:</strong> {{timestamp}}</p>
                
                <h3>Message:</h3>
                <p>{{message}}</p>
            </div>
            
            <p><em>This feedback was automatically forwarded from {{platformName}}.</em></p>
        </div>
    </div>
</body>
</html>