{
  "name": "statsor-backend",
  "version": "1.0.0",
  "description": "Production-ready backend for Statsor football analytics platform",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "concurrently \"npm run dev:gateway\" \"npm run dev:user\" \"npm run dev:team\" \"npm run dev:match\" \"npm run dev:analytics\"",
    "dev:gateway": "nodemon src/services/api-gateway/index.ts",
    "dev:user": "nodemon src/services/user-service/index.ts",
    "dev:team": "nodemon src/services/team-service/index.ts",
    "dev:match": "nodemon src/services/match-service/index.ts",
    "dev:analytics": "nodemon src/services/analytics-service/index.ts",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "migrate": "knex migrate:latest",
    "migrate:rollback": "knex migrate:rollback",
    "seed": "knex seed:run",
    "docker:build": "docker build -t statsor-backend .",
    "docker:run": "docker run -p 3000:3000 statsor-backend",
    "k8s:deploy": "kubectl apply -f k8s/",
    "docs:generate": "swagger-jsdoc -d swaggerDef.js src/services/**/*.ts -o docs/swagger.json"
  },
  "dependencies": {
    "express": "^4.18.2",
    "fastify": "^4.24.3",
    "apollo-server-express": "^3.12.1",
    "graphql": "^16.8.1",
    "@grpc/grpc-js": "^1.9.7",
    "@grpc/proto-loader": "^0.7.10",
    "jsonwebtoken": "^9.0.2",
    "passport": "^0.6.0",
    "passport-jwt": "^4.0.1",
    "passport-oauth2": "^1.7.0",
    "bcryptjs": "^2.4.3",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "pg": "^8.11.3",
    "knex": "^3.0.1",
    "redis": "^4.6.10",
    "mongodb": "^6.2.0",
    "mongoose": "^7.6.3",
    "amqplib": "^0.10.3",
    "winston": "^3.11.0",
    "prom-client": "^15.0.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0",
    "joi": "^17.11.0",
    "dotenv": "^16.3.1",
    "compression": "^1.7.4",
    "morgan": "^1.10.0",
    "uuid": "^9.0.1",
    "lodash": "^4.17.21",
    "moment": "^2.29.4",
    "axios": "^1.6.0",
    "socket.io": "^4.7.4",
    "ioredis": "^5.3.2"
  },
  "devDependencies": {
    "@types/node": "^20.8.7",
    "@types/express": "^4.17.20",
    "@types/jsonwebtoken": "^9.0.4",
    "@types/bcryptjs": "^2.4.5",
    "@types/cors": "^2.8.15",
    "@types/compression": "^1.7.4",
    "@types/morgan": "^1.9.7",
    "@types/uuid": "^9.0.6",
    "@types/lodash": "^4.14.200",
    "@types/jest": "^29.5.6",
    "@types/supertest": "^2.0.15",
    "typescript": "^5.2.2",
    "ts-node": "^10.9.1",
    "nodemon": "^3.0.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "supertest": "^6.3.3",
    "eslint": "^8.52.0",
    "@typescript-eslint/eslint-plugin": "^6.9.0",
    "@typescript-eslint/parser": "^6.9.0",
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  }
}